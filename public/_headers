# ================================================
# Security Headers (all routes)
# ================================================
/*
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://analytics.ahrefs.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://ogmcthsegdafuiehqiem.supabase.co https://www.google-analytics.com https://analytics.ahrefs.com https://api.emailjs.com https://analytics.google.com; frame-src https://beds24.com https://www.beds24.com https://maps.google.com https://www.google.com; frame-ancestors 'none'

# ================================================
# Cache Headers
# ================================================

# Cache hashed Vite assets for 1 year (immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache static images for 1 month
/photos/*
  Cache-Control: public, max-age=2592000

# Cache fonts for 1 year
*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Cache SVG logos for 1 week
/*.svg
  Cache-Control: public, max-age=604800

# Cache favicon
/favicon.png
  Cache-Control: public, max-age=2592000
